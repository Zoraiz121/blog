<% flash_class_map = {
  "notice" => "alert-success",
  "success" => "alert-success",
  "alert" => "alert-warning",
  "error" => "alert-danger"
} %>

<% flash.each do |type, message| %>
  <% next if message.blank? %>

  <div class="alert <%= flash_class_map.fetch(type, "alert-info") %> alert-dismissible fade show mb-0 rounded-0" role="alert">
    <%= message %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% end %>