<div class="container my-5">
  <div class="card border-0 shadow-sm mb-5">
    <div class="card-body p-5 text-center">
      <div class="profile-avatar mx-auto mb-3">
        <%= (@user.name.presence || @user.email).first.upcase %>
      </div>

      <h2 class="fw-bold mb-1">
        <%= @user.name.presence || "Blog Author" %>
      </h2>

      <p class="text-muted mb-0"><%= @user.email %></p>
      <p class="mt-3 mb-0">
        <strong><%= @articles.count %></strong> articles published
      </p>
    </div>
  </div>

  <h3 class="fw-bold mb-4">Articles by this author</h3>

  <div class="row g-4">
    <% @articles.each do |article| %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 border-0 shadow-sm article-card">
          <div class="card-body p-4">
            <h4 class="fw-bold"><%= link_to article.title, article_path(article), class: "text-dark text-decoration-none" %></h4>
            <p class="text-muted"><%= truncate(article.body, length: 120) %></p>
            <%= link_to "Read Article", article_path(article), class: "btn btn-dark btn-sm" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>