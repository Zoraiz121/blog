<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6">

      <div class="card shadow">
        <div class="card-body p-4">

          <h3 class="text-center mb-4">Edit Your Profile</h3>

          <%= render "devise/shared/error_messages", resource: resource %>

          <%= form_for(resource,
                as: resource_name,
                url: registration_path(resource_name),
                html: { method: :put }) do |f| %>

            <%# ── Profile fields ──────────────────────────────────── %>
            <h6 class="text-muted text-uppercase fw-bold small mb-3 mt-2">
              Profile Information
            </h6>

            <div class="mb-3">
              <%= f.label :name, class: "form-label" %>
              <%= f.text_field :name,
                    class: "form-control",
                    placeholder: "Your display name",
                    autocomplete: "name" %>
              <div class="form-text">
                Appears on your articles and public profile.
              </div>
            </div>

            <div class="mb-4">
              <%= f.label :occupation, class: "form-label" %>
              <%= f.text_field :occupation,
                    class: "form-control",
                    placeholder: "e.g. Software Engineer, Writer, Designer",
                    autocomplete: "organization-title" %>
            </div>

            <%# ── Account credential fields ───────────────────────── %>
            <h6 class="text-muted text-uppercase fw-bold small mb-3">
              Account Credentials
            </h6>

            <div class="mb-3">
              <%= f.label :email, class: "form-label" %>
              <%= f.email_field :email,
                    class: "form-control",
                    autofocus: true,
                    autocomplete: "email" %>

              <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
                <div class="form-text text-warning">
                  Currently awaiting confirmation for:
                  <strong><%= resource.unconfirmed_email %></strong>
                </div>
              <% end %>
            </div>

            <div class="mb-3">
              <%= f.label :password, class: "form-label" %>
              <span class="text-muted small">
                (leave blank to keep current password)
              </span>
              <%= f.password_field :password,
                    class: "form-control",
                    autocomplete: "new-password" %>
              <% if @minimum_password_length %>
                <div class="form-text">
                  <%= @minimum_password_length %> characters minimum.
                </div>
              <% end %>
            </div>

            <div class="mb-3">
              <%= f.label :password_confirmation, class: "form-label" %>
              <%= f.password_field :password_confirmation,
                    class: "form-control",
                    autocomplete: "new-password" %>
            </div>

            <div class="mb-4">
              <%= f.label :current_password, class: "form-label" %>
              <span class="text-muted small">
                (required to save any changes)
              </span>
              <%= f.password_field :current_password,
                    class: "form-control",
                    autocomplete: "current-password" %>
            </div>

            <div class="d-grid mb-3">
              <%= f.submit "Save Changes", class: "btn btn-primary btn-lg" %>
            </div>

          <% end %>

          <hr>

          <%# ── Danger zone ─────────────────────────────────────── %>
          <div class="text-center">
            <p class="text-muted small mb-2">
              Want to leave? This action is permanent and cannot be undone.
            </p>
            <%= button_to "Delete My Account",
                  registration_path(resource_name),
                  data: {
                    confirm: "Are you sure you want to delete your account?",
                    turbo_confirm: "Are you sure you want to delete your account?"
                  },
                  method: :delete,
                  class: "btn btn-outline-danger btn-sm" %>
          </div>

          <div class="text-center mt-3 small">
            <%= render "devise/shared/links" %>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>