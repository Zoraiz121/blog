<!DOCTYPE html>
<html>
  <head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title><%= content_for(:title) || "Blog" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
   <nav class="navbar navbar-dark bg-dark px-3">

  <a class="navbar-brand" href="/articles">My Blog</a>

  <div class="ms-auto">
    <% if user_signed_in? %>
      <%= button_to "Sign Out",
          destroy_user_session_path,
          method: :delete,
          class: "btn btn-danger btn-sm" %>
    <% else %>
      <%= link_to "Login", new_user_session_path, class: "btn btn-success btn-sm me-2" %>
      <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-primary btn-sm" %>
    <% end %>
  </div>

</nav>
    <%= yield %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
