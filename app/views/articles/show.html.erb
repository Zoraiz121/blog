<div class="container my-5">
  <%= link_to "← Back to Articles", articles_path, class: "btn btn-outline-secondary mb-4" %>

  <div class="card border-0 shadow-sm mb-5">
    <div class="card-body p-4 p-md-5">
      <% if @article.cover_image.attached? %>
        <%= image_tag @article.cover_image,
            class: "w-100 rounded mb-4",
            style: "max-height: 500px; object-fit: cover;" %>
      <% elsif @article.image.attached? %>
        <%= image_tag @article.image,
            class: "w-100 rounded mb-4",
            style: "max-height: 500px; object-fit: cover;" %>
      <% end %>

      <h1 class="fw-bold mb-3"><%= @article.title %></h1>

      <p class="text-muted mb-4">
        Published on <%= @article.created_at.strftime("%B %d, %Y") %>
      </p>

      <div class="fs-5">
        <%= simple_format(@article.body) %>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <h3 class="fw-bold mb-4">Comments</h3>

      <% if user_signed_in? %>
        <%= form_with model: [@article, @comment], local: true do |f| %>
          <div class="mb-3">
            <%= f.text_area :body,
                rows: 3,
                class: "form-control",
                placeholder: "Write a comment..." %>
          </div>

          <%= f.submit "Add Comment", class: "btn btn-dark btn-sm mb-4" %>
        <% end %>
      <% else %>
        <p class="text-muted">
          Please <%= link_to "sign in", new_user_session_path %> to comment.
        </p>
      <% end %>

      <% if @comments.any? %>
        <% @comments.each do |comment| %>
          <div class="border rounded p-3 mb-3">
            <p class="mb-2"><%= comment.body %></p>

            <div class="d-flex justify-content-between align-items-center">
              <small class="text-muted">
                By <%= comment.user.name.presence || comment.user.email %>
              </small>

              <% if user_signed_in? && comment.user_id == current_user.id %>
                <div class="d-flex gap-2">
                  <%= link_to "Edit",
                      edit_article_comment_path(@article, comment),
                      class: "btn btn-outline-primary btn-sm" %>

                  <%= button_to "Delete",
                      article_comment_path(@article, comment),
                      method: :delete,
                      data: { turbo_confirm: "Are you sure?" },
                      class: "btn btn-outline-danger btn-sm" %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="text-muted mb-0">No comments yet.</p>
      <% end %>
    </div>
  </div>
</div>