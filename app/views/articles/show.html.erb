<div class="container my-5">
  <%= link_to "← Back to Articles", articles_path, class: "btn btn-outline-secondary mb-4" %>

<% if @article.cover_image.attached? %>
  <%= image_tag @article.cover_image,
      class: "w-100 rounded mb-4",
      style: "max-height: 500px; object-fit: cover;" %>
<% elsif @article.image.attached? %>
  <%= image_tag @article.image,
      class: "w-100 rounded mb-4",
      style: "max-height: 500px; object-fit: cover;" %>
<% end %>

  <h1><%= @article.title %></h1>
  <p class="text-muted">Published on <%= @article.created_at.strftime("%B %d, %Y") %></p>

  <div class="mb-5">
    <%= simple_format(@article.body) %>
  </div>

  <hr>

  <h3>Comments</h3>

  <% if user_signed_in? %>
    <%= form_with model: [@article, @comment], local: true do |f| %>
      <%= f.text_area :body, rows: 3, class: "form-control mb-2", placeholder: "Write a comment..." %>
      <%= f.submit "Add Comment", class: "btn btn-dark btn-sm mb-4" %>
    <% end %>
  <% end %>

  <% @comments.each do |comment| %>
    <div class="border rounded p-3 mb-3">
      <p><%= comment.body %></p>

      <small class="text-muted">
        By <%= comment.user.name.presence || comment.user.email %>
      </small>

      <% if user_signed_in? && comment.user == current_user %>
        <div class="mt-2 d-flex gap-2">
          <%= link_to "Edit", edit_article_comment_path(@article, comment), class: "btn btn-outline-primary btn-sm" %>

          <%= button_to "Delete",
              article_comment_path(@article, comment),
              method: :delete,
              data: { turbo_confirm: "Are you sure?" },
              class: "btn btn-outline-danger btn-sm" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>