<div class="article-show-page">
  <div class="container my-5">
    <%= link_to "← Back to Articles", articles_path, class: "btn btn-outline-secondary mb-4" %>

    <article class="card border-0 shadow-sm overflow-hidden">
      <% if @article.cover_image.attached? %>
        <%= image_tag @article.cover_image,
            class: "article-hero-img",
            alt: @article.title %>
      <% elsif @article.image.attached? %>
        <%= image_tag @article.image,
            class: "article-hero-img",
            alt: @article.title %>
      <% end %>

      <div class="card-body p-4 p-md-5">
        <div class="mb-3">
          <span class="badge bg-dark-subtle text-dark px-3 py-2">
            <%= @article.status.presence || "Published" %>
          </span>
        </div>

        <h1 class="display-6 fw-bold mb-3">
          <%= @article.title %>
        </h1>

        <div class="d-flex flex-wrap gap-3 text-muted mb-4 small">
          <span>
            Published on <%= @article.created_at.strftime("%B %d, %Y") %>
          </span>

          <% if @article.user.present? %>
            <span>
              By <%= @article.user.name.presence || @article.user.email %>
            </span>
          <% end %>
        </div>

        <% if user_signed_in? && @article.user_id == current_user.id %>
          <div class="d-flex gap-2 mb-4">
            <%= link_to "Edit Article", edit_article_path(@article), class: "btn btn-outline-primary btn-sm px-3" %>

            <%= button_to "Delete Article",
                article_path(@article),
                method: :delete,
                data: { turbo_confirm: "Are you sure?" },
                class: "btn btn-outline-danger btn-sm px-3" %>
          </div>
        <% end %>

        <div class="article-content">
          <%= simple_format(@article.body) %>
        </div>
      </div>
    </article>

    <section class="card border-0 shadow-sm mt-5">
      <div class="card-body p-4 p-md-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <div>
            <h3 class="fw-bold mb-1">Comments</h3>
            <p class="text-muted mb-0">
              Join the discussion below
            </p>
          </div>

          <span class="badge rounded-pill bg-dark">
            <%= @comments.count %>
          </span>
        </div>

        <% if user_signed_in? %>
          <div class="comment-form-box mb-4">
            <%= form_with model: [@article, @comment], local: true do |f| %>
              <div class="mb-3">
                <%= f.text_area :body,
                    rows: 3,
                    class: "form-control",
                    placeholder: "Write your comment..." %>
              </div>

              <%= f.submit "Post Comment", class: "btn btn-dark px-4" %>
            <% end %>
          </div>
        <% else %>
          <div class="alert alert-light border">
            Please <%= link_to "sign in", new_user_session_path, class: "fw-semibold" %> to write a comment.
          </div>
        <% end %>

        <% if @comments.any? %>
          <div class="comments-list">
            <% @comments.each do |comment| %>
              <div class="comment-item">
                <div class="comment-avatar">
                  <%= (comment.user.name.presence || comment.user.email).first.upcase %>
                </div>

                <div class="comment-body">
                  <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                      <h6 class="fw-bold mb-1">
                        <%= comment.user.name.presence || comment.user.email %>
                      </h6>

                      <small class="text-muted">
                        <%= comment.created_at.strftime("%b %d, %Y at %I:%M %p") %>
                      </small>
                    </div>

                    <% if user_signed_in? && comment.user_id == current_user.id %>
                      <div class="d-flex gap-2">
                        <%= link_to "Edit",
                            edit_article_comment_path(@article, comment),
                            class: "btn btn-outline-primary btn-sm" %>

                        <%= button_to "Delete",
                            article_comment_path(@article, comment),
                            method: :delete,
                            data: { turbo_confirm: "Are you sure?" },
                            class: "btn btn-outline-danger btn-sm" %>
                      </div>
                    <% end %>
                  </div>

                  <p class="mt-3 mb-0">
                    <%= comment.body %>
                  </p>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="empty-comments text-center py-4">
            <h5 class="mb-1">No comments yet</h5>
            <p class="text-muted mb-0">Be the first to share your thoughts.</p>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>