<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-1">My Articles</h1>
      <p class="text-muted mb-0">Manage and explore your latest blog posts</p>
    </div>

    <% if user_signed_in? %>
      <%= link_to "+ New Article", new_article_path, class: "btn btn-dark px-4" %>
    <% end %>
  </div>

  <% if @articles.empty? %>
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <p class="text-muted mb-3">No articles yet.</p>

        <% if user_signed_in? %>
          <%= link_to "Write your first article", new_article_path, class: "btn btn-dark" %>
        <% end %>
      </div>
    </div>
  <% else %>
    <% @articles.each do |article| %>
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
          <h3 class="mb-2">
            <%= link_to article.title, article_path(article), class: "text-dark text-decoration-none" %>
          </h3>

          <p class="text-muted">
            <%= truncate(article.body, length: 180) %>
          </p>

          <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">
              <%= article.created_at.strftime("%B %d, %Y") %>
              <% if article.user.present? %>
                by <%= article.user.name.presence || article.user.email %>
              <% end %>
              · <%= article.comments_count %> <%= "comment".pluralize(article.comments_count) %>
            </small>

            <div class="d-flex gap-2">
              <%= link_to "View", article_path(article), class: "btn btn-outline-dark btn-sm" %>

              <% if user_signed_in? && article.user_id == current_user.id %>
                <%= link_to "Edit", edit_article_path(article), class: "btn btn-outline-primary btn-sm" %>

                <%= button_to "Delete",
                    article_path(article),
                    method: :delete,
                    data: { turbo_confirm: "Are you sure?" },
                    class: "btn btn-outline-danger btn-sm" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <%= render "shared/pagination", pagy: @pagy %>
  <% end %>
</div>