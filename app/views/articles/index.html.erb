<section class="hero-section">
  <div class="container">
    <div class="row align-items-center py-5">
      <div class="col-lg-8">
        <span class="badge rounded-pill bg-light text-dark mb-3 px-3 py-2">
          Personal Blog Platform
        </span>

        <h1 class="display-5 fw-bold text-white mb-3">
          Explore Latest Articles
        </h1>

        <p class="lead text-white-50 mb-0">
          Read, write, and manage clean blog posts with comments and secure ownership.
        </p>
      </div>

      <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
        <% if user_signed_in? %>
          <%= link_to "+ Write New Article", new_article_path, class: "btn btn-light btn-lg px-4 shadow-sm" %>
        <% else %>
          <%= link_to "Sign in to write", new_user_session_path, class: "btn btn-light btn-lg px-4 shadow-sm" %>
        <% end %>
      </div>
    </div>
  </div>
</section>

<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-1">All Articles</h2>
      <p class="text-muted mb-0">Browse all published blog posts</p>
    </div>
  </div>

  <% if @articles.empty? %>
    <div class="empty-state">
      <h4>No articles yet</h4>
      <p class="text-muted">Start by creating your first article.</p>

      <% if user_signed_in? %>
        <%= link_to "Create Article", new_article_path, class: "btn btn-dark px-4" %>
      <% end %>
    </div>
  <% else %>
    <div class="row g-4">
      <% @articles.each do |article| %>
        <div class="col-md-6 col-lg-4">
          <div class="article-card card h-100 border-0 shadow-sm">
            <% if article.cover_image.attached? %>
              <%= image_tag article.cover_image,
                  class: "card-img-top article-card-img",
                  alt: article.title %>
            <% elsif article.image.attached? %>
              <%= image_tag article.image,
                  class: "card-img-top article-card-img",
                  alt: article.title %>
            <% else %>
              <div class="article-card-placeholder">
                <span><%= article.title.first&.upcase || "B" %></span>
              </div>
            <% end %>

            <div class="card-body d-flex flex-column p-4">
              <div class="mb-3">
                <span class="badge bg-dark-subtle text-dark">
                  <%= article.status.presence || "Published" %>
                </span>
              </div>

              <h4 class="fw-bold mb-2">
                <%= link_to article.title,
                    article_path(article),
                    class: "text-dark text-decoration-none stretched-title" %>
              </h4>

              <p class="text-muted flex-grow-1">
                <%= truncate(strip_tags(article.body.to_s), length: 130) %>
              </p>

              <div class="article-meta mb-3">
                <span>
                  <%= article.created_at.strftime("%b %d, %Y") %>
                </span>

                <span>•</span>

                <span>
                  <%= pluralize(article.comments_count, "comment") rescue pluralize(article.comments.count, "comment") %>
                </span>
              </div>

              <div class="d-flex gap-2 flex-wrap">
                <%= link_to "View", article_path(article), class: "btn btn-dark btn-sm px-3" %>

                <% if user_signed_in? && article.user_id == current_user.id %>
                  <%= link_to "Edit", edit_article_path(article), class: "btn btn-outline-primary btn-sm px-3" %>

                  <%= button_to "Delete",
                      article_path(article),
                      method: :delete,
                      data: { turbo_confirm: "Are you sure?" },
                      class: "btn btn-outline-danger btn-sm px-3" %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-5">
      <%= render "shared/pagination", pagy: @pagy if defined?(@pagy) && @pagy.present? %>
    </div>
  <% end %>
</div>