<section class="hero-section">
  <div class="container">
    <div class="row align-items-center py-5">
      <div class="col-lg-8">
        <span class="badge rounded-pill bg-light text-dark mb-3 px-3 py-2">
          Rails Blog Platform
        </span>

        <h1 class="display-5 fw-bold text-white mb-3">
          Explore Latest Articles
        </h1>

        <p class="lead text-white-50 mb-0">
          Read, write, and manage blog posts with comments and secure ownership.
        </p>
      </div>

      <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
        <% if user_signed_in? %>
          <%= link_to "+ Write New Article", new_article_path, class: "btn btn-light btn-lg px-4 shadow-sm" %>
        <% else %>
          <%= link_to "Sign in to write", new_user_session_path, class: "btn btn-light btn-lg px-4 shadow-sm" %>
        <% end %>
      </div>
    </div>
  </div>
</section>

<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-1">All Articles</h2>
      <p class="text-muted mb-0">Browse all blog posts</p>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <%= form_with url: articles_path, method: :get, local: true, class: "d-flex gap-2" do |f| %>
        <%= f.text_field :query,
            value: params[:query],
            class: "form-control",
            placeholder: "Search articles by title or content..." %>

        <%= f.submit "Search", class: "btn btn-dark px-4" %>

        <% if params[:query].present? %>
          <%= link_to "Clear", articles_path, class: "btn btn-outline-secondary" %>
        <% end %>
      <% end %>
    </div>
  </div>

  <% if @articles.empty? %>
    <div class="empty-state text-center">
      <h4>No articles yet</h4>
      <p class="text-muted">Start by creating your first article.</p>

      <% if user_signed_in? %>
        <%= link_to "Create Article", new_article_path, class: "btn btn-dark px-4" %>
      <% end %>
    </div>
  <% else %>
    <div class="row g-4">
      <% @articles.each do |article| %>
        <div class="col-md-6 col-lg-4">
          <div class="article-card card h-100 border-0 shadow-sm">
            <% if article.cover_image.attached? %>
              <%= image_tag article.cover_image, class: "card-img-top article-card-img", alt: article.title %>
            <% elsif article.image.attached? %>
              <%= image_tag article.image, class: "card-img-top article-card-img", alt: article.title %>
            <% else %>
              <div class="article-card-placeholder">
                <span><%= article.title.first&.upcase || "B" %></span>
              </div>
            <% end %>

            <div class="card-body d-flex flex-column p-4">
              <div class="d-flex gap-2 mb-3 flex-wrap">
                <% if article.category.present? %>
                  <span class="badge bg-primary-subtle text-primary">
                    <%= article.category %>
                  </span>
                <% end %>

                <span class="badge bg-dark-subtle text-dark">
                  <%= article.status == "public" ? "Published" : article.status.to_s.titleize %>
                </span>
              </div>

              <h4 class="fw-bold mb-2 article-card-title">
                <%= link_to article.title, article_path(article), class: "text-dark text-decoration-none" %>
              </h4>

              <p class="text-muted article-card-excerpt flex-grow-1">
                <%= truncate(strip_tags(article.body.to_s), length: 130) %>
              </p>

              <div class="article-meta mb-3">
                <span><%= article.created_at.strftime("%b %d, %Y") %></span>
                <span>•</span>
                <span><%= pluralize(article.comments_count, "comment") %></span>
              </div>

              <div class="d-flex gap-2 flex-wrap mt-auto">
                <%= link_to "View", article_path(article), class: "btn btn-dark btn-sm px-3" %>

                <% if user_signed_in? && article.user_id == current_user.id %>
                  <%= link_to "Edit", edit_article_path(article), class: "btn btn-outline-primary btn-sm px-3" %>

                  <%= button_to "Delete",
                      article_path(article),
                      method: :delete,
                      data: { turbo_confirm: "Are you sure?" },
                      class: "btn btn-outline-danger btn-sm px-3" %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>